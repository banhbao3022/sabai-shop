# ---------------------------------------------------------------------------
# Sabai Shop — environment variables
# Copy this file to `.env.local` and adjust. All values are optional; the app
# runs with sensible defaults if nothing is set.
# ---------------------------------------------------------------------------

# Passcode for the /admin panel. Client-side only — this is a light gate for a
# demo, NOT real authentication. Change it before sharing a deployment.
NEXT_PUBLIC_ADMIN_PASSCODE=admin

# Set to "true" to produce a static export (writes ./out) for GitHub Pages or
# any static host. Leave unset for Vercel / Netlify / Cloudflare (SSR builds).
# NEXT_EXPORT=true

# Sub-path the site is served under, e.g. "/my-repo" for GitHub Pages project
# sites (https://user.github.io/my-repo). Leave empty for root/custom domains.
# NEXT_PUBLIC_BASE_PATH=/my-repo

# Absolute public site URL used for canonical tags, sitemap, OpenGraph, etc.
# Vercel example: https://sabai-shop.vercel.app
# GitHub Pages example: https://user.github.io/my-repo
# NEXT_PUBLIC_SITE_URL=https://sabai-shop.vercel.app
